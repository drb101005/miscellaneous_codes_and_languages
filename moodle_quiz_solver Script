(async function groqQuizSolver() {
  const API_KEY = "Key!!";
  const MODEL   = "llama-3.3-70b-versatile";

  const sleep = ms => new Promise(r => setTimeout(r, ms));

  function log(msg) {
    console.log(
      "%c[Groq Quiz]%c " + msg + " %c| github.com/drb101005",
      "color:#7F77DD;font-weight:bold",
      "color:inherit",
      "color:#00C896;font-weight:bold"
    );
  }

  function parseQuestion(el) {
    const qText =
      el.querySelector('.qtext, .question-text, [class*="qtext"]')
        ?.innerText?.trim() ||
      el.querySelector('p')?.innerText?.trim() ||
      el.innerText?.split("\n")[0]?.trim() || "";

    const options = [];
    el.querySelectorAll('input[type="radio"], input[type="checkbox"]')
      .forEach((inp, i) => {
        const label =
          inp.closest('label') ||
          document.querySelector(`label[for="${inp.id}"]`) ||
          inp.parentElement;
        options.push({
          el: inp,
          text: label?.innerText?.trim() || "Option " + (i + 1),
          index: i
        });
      });

    return { qText, options };
  }

  async function askGroq(question, options) {
    const numbered = options.map((o, i) => (i + 1) + ". " + o.text).join("\n");

    const prompt =
      "You are answering a quiz question for testing purposes. " +
      "Reply ONLY with the number(s) of the correct answer(s), " +
      "comma-separated if multiple. No explanation.\n\n" +
      "Question: " + question + "\n\nOptions:\n" + numbered;

    const res = await fetch("https://api.groq.com/openai/v1/chat/completions", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + API_KEY
      },
      body: JSON.stringify({
        model: MODEL,
        max_tokens: 32,
        temperature: 0,
        messages: [{ role: "user", content: prompt }]
      })
    });

    if (!res.ok) {
      const e = await res.json().catch(() => ({}));
      throw new Error(e?.error?.message || "HTTP " + res.status);
    }

    const data = await res.json();
    const reply = data.choices?.[0]?.message?.content?.trim() || "";

    return reply
      .split(",")
      .map(n => parseInt(n.trim()) - 1)
      .filter(n => !isNaN(n));
  }

  async function answerQuestion(el, idx) {
    const { qText, options } = parseQuestion(el);

    if (!qText || options.length === 0) {
      log("Q" + (idx + 1) + ": skipped (no text/options detected)");
      return;
    }

    log("Q" + (idx + 1) + ": querying Groq...");
    log('→ "' + qText.slice(0, 90) + (qText.length > 90 ? "…" : "") + '"');

    try {
      const correct = await askGroq(qText, options);

      if (correct.length === 0) {
        log("✗ Could not parse answer");
        return;
      }

      correct.forEach(ci => {
        if (options[ci]) {
          options[ci].el.click();
          log('✓ Selected: "' + options[ci].text + '"');
        }
      });

    } catch (e) {
      log("✗ Error: " + e.message);
    }

    await sleep(350);
  }

  function clickNext() {
    const btn =
      document.querySelector('input[type="submit"][value*="Next"]') ||
      document.querySelector('input[type="submit"][value*="next"]') ||
      document.querySelector('input[type="submit"][value*="Continue"]') ||
      document.querySelector('button[type="submit"]') ||
      document.querySelector('input[type="submit"]');

    if (btn) {
      btn.click();
      return true;
    }
    return false;
  }

  log("Starting — model: " + MODEL);
  log("Created by github.com/drb101005");

  let page = 1;

  while (true) {
    log("── Page " + page + " ──");
    await sleep(1200);

    const questions = document.querySelectorAll('.que');

    if (questions.length === 0) {
      log("No questions found. Finished!");
      break;
    }

    log("Found " + questions.length + " question(s)");

    for (let i = 0; i < questions.length; i++) {
      await answerQuestion(questions[i], i);
    }

    log("All questions answered — moving to next page...");
    await sleep(800);

    const moved = clickNext();

    if (!moved) {
      log("No Next button found. Quiz complete!");
      break;
    }

    page++;
    await sleep(3500);
  }
})();
